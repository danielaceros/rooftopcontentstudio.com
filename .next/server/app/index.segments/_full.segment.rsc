2:T41d,{"@context":"https://schema.org","@type":"LocalBusiness","@id":"https://therooftopcontentstudio.com/#business","name":"Rooftop Content Studio","description":"Estudio de grabación de contenido premium en Madrid. Graba meses de contenido en una sola mañana con un equipo profesional en una localización exclusiva.","url":"https://therooftopcontentstudio.com","telephone":"+34 600 000 000","email":"hola@therooftopcontentstudio.com","address":{"@type":"PostalAddress","streetAddress":"Centro de Madrid, España","addressLocality":"Madrid","postalCode":"28001","addressCountry":"ES"},"geo":{"@type":"GeoCoordinates","latitude":40.4168,"longitude":-3.7038},"image":"https://therooftopcontentstudio.com/optimized/og-image.webp","priceRange":"€€","openingHoursSpecification":[{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"09:00","closes":"20:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Saturday","opens":"10:00","closes":"18:00"}],"areaServed":{"@type":"City","name":"Madrid"}}3:T724,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"¿Necesito experiencia delante de la cámara?","acceptedAnswer":{"@type":"Answer","text":"No. Nuestro equipo de dirección te guiará en todo momento. Además, contamos con teleprompter para que no tengas que memorizar nada."}},{"@type":"Question","name":"¿Qué incluye exactamente el servicio?","acceptedAnswer":{"@type":"Answer","text":"Incluye el uso del estudio, equipo técnico (cámaras, iluminación, sonido), dirección creativa, maquillaje, teleprompter y la edición completa de todas las piezas grabadas."}},{"@type":"Question","name":"¿Cuánto contenido puedo grabar en una sesión?","acceptedAnswer":{"@type":"Answer","text":"En una media jornada puedes grabar hasta 10 piezas (reels, clips, etc.). En una jornada completa, hasta 25 piezas más una sesión de fotos."}},{"@type":"Question","name":"¿En cuánto tiempo recibo el contenido editado?","acceptedAnswer":{"@type":"Answer","text":"El plazo estándar de entrega es de 5 días laborables desde la fecha de grabación."}},{"@type":"Question","name":"¿Puedo traer a mi propio equipo?","acceptedAnswer":{"@type":"Answer","text":"Por supuesto. Si tienes un fotógrafo, videógrafo o maquillador de confianza, pueden acompañarte sin coste adicional por el uso del espacio."}},{"@type":"Question","name":"¿Dónde está el estudio?","acceptedAnswer":{"@type":"Answer","text":"Estamos en el centro de Madrid, en una terraza rooftop privada con vistas panorámicas a la ciudad. Te enviaremos la dirección exacta al confirmar tu reserva."}},{"@type":"Question","name":"¿Cómo reservo una sesión?","acceptedAnswer":{"@type":"Answer","text":"Rellena el formulario de contacto o escríbenos por email. Te responderemos en menos de 24 horas para agendar tu sesión."}}]}0:{"P":null,"b":"WOzP1YM1guwa3x1M7vL21","c":["",""],"q":"","i":false,"f":[[["",{"children":["__PAGE__",{}]},"$undefined","$undefined",true],[["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/2df398f0ce1a302a.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","html",null,{"lang":"es","className":"bebas_neue_81b9ade6-module__JpKy0W__variable dm_sans_efc253b3-module__w1i8Da__variable","children":[["$","head",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$3"}}]]}],"$L4"]}]]}],{"children":["$L5",{},null,false,false]},null,false,false],"$L6",false]],"m":"$undefined","G":["$7",[]],"S":true}
